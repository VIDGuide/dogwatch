[Unit]
Description=DogWatch MQTT event notifier
After=network-online.target
Wants=network-online.target

[Service]
Environment=MQTT_HOST=127.0.0.1
Environment=MQTT_PORT=1883
Environment=MQTT_TOPIC=dogwatch
ExecStart=/home/misaunders/.openclaw/workspace/scripts/dogwatch-venv/bin/python /home/misaunders/.openclaw/workspace/scripts/dogwatch-notify.py
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
